# FastAPI AI Engine Configuration

# Debug mode
DEBUG=true

# Backend API (Django)
BACKEND_API_URL=http://localhost:8000
BACKEND_API_KEY=

# LLM Configuration
# Leave empty to use OpenClaw fallback
LLM_PROVIDER=          # openai | anthropic | google
LLM_API_KEY=           # Your API key
LLM_MODEL=gpt-4-turbo  # backward-compat fallback when tier vars are unset

# Two-tier LLM routing
# FAST    → push/commit events → student inline feedback  (cheap, quick)
# QUALITY → PR grading         → teacher rubric draft     (best model)
# Both fall back to LLM_MODEL when left empty.
LLM_MODEL_FAST=gpt-4o-mini        # or claude-haiku-4-5 / gemini-2.0-flash-lite
LLM_MODEL_QUALITY=gpt-4-turbo     # or claude-sonnet-4-5 / gemini-1.5-pro

# OpenClaw Fallback (when no LLM key configured)
OPENCLAW_ENABLED=true
OPENCLAW_WEBHOOK_URL=http://localhost:18789/webhook
OPENCLAW_API_KEY=

# GitHub Webhook
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Git Cache Directory
GIT_CACHE_DIR=./repos
