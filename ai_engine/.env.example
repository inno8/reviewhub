# FastAPI AI Engine Configuration

# Debug mode
DEBUG=true

# Backend API (Django)
BACKEND_API_URL=http://localhost:8000
BACKEND_API_KEY=

# LLM Configuration
# Leave empty to use OpenClaw fallback
LLM_PROVIDER=          # openai | anthropic | google
LLM_API_KEY=           # Your API key
LLM_MODEL=gpt-4-turbo  # backward-compat fallback when tier vars are unset

# Two-tier LLM routing — IMPORTANT: model names must match LLM_PROVIDER above.
# Mixing an Anthropic provider with an OpenAI model name (or vice versa)
# produces a 404 from the upstream API.
#
# PR_LLM_MODEL    → PR grading → teacher rubric draft (best available model)
# COMMIT_LLM_MODEL → push/commit events → student inline feedback (cheap, fast)
# Both fall back to their legacy names (LLM_MODEL_QUALITY / LLM_MODEL_FAST) or
# LLM_MODEL when unset.
PR_LLM_MODEL=claude-sonnet-4-5-20250929     # for LLM_PROVIDER=anthropic
COMMIT_LLM_MODEL=claude-haiku-4-5-20250929  # for LLM_PROVIDER=anthropic
# Legacy names, kept for backward-compat — leave empty if you set PR_/COMMIT_:
LLM_MODEL_FAST=
LLM_MODEL_QUALITY=

# OpenClaw Fallback (when no LLM key configured)
OPENCLAW_ENABLED=true
OPENCLAW_WEBHOOK_URL=http://localhost:18789/webhook
OPENCLAW_API_KEY=

# GitHub Webhook
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Git Cache Directory
GIT_CACHE_DIR=./repos
