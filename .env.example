# ReviewHub Environment Variables
# Copy this file to .env and fill in the values

# Database
DB_PASSWORD=reviewhub_dev

# Django
SECRET_KEY=change-me-in-production
DEBUG=false

# Frontend URL (OAuth redirect back to Settings after Google sign-in)
FRONTEND_URL=http://localhost:5173
# Public Django base URL (must match Google OAuth redirect URI registration)
BACKEND_PUBLIC_URL=http://localhost:8000
# Google OAuth for Gemini (Settings → LLM → Sign in with Google)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Internal API communication (Django <-> FastAPI)
INTERNAL_API_KEY=dev-internal-key

# LLM Provider (leave empty for OpenClaw rule-based fallback)
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=gpt-4-turbo

# GitHub Webhook
GITHUB_WEBHOOK_SECRET=

# Optional: Telegram notifications
TELEGRAM_BOT_TOKEN=
