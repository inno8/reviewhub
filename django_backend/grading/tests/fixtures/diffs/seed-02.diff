+from app.api_client import HTTPClient, HTTPError, HTTPTimeout
+
+logger = logging.getLogger(__name__)
+
+
+def get_order(order_id: int, client: HTTPClient) -> Optional[dict]:
+    """Fetch one order from the upstream API.
+
+    Returns None if the order does not exist. Raises HTTPError for any
+    other upstream failure so callers can decide whether to retry.
+    """
+    try:
+        return client.get_json(f"/orders/{order_id}")
+    except HTTPTimeout:
+        logger.warning("order %s fetch timed out", order_id)
+        raise
+    except HTTPError as e:
+        if e.status == 404:
+            return None
+        raise
