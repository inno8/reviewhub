@@ -0,0 +1,24 @@
+import pytest
+from unittest.mock import MagicMock
+from app.order_service import get_order
+from app.api_client import HTTPError, HTTPTimeout
+
+
+def test_returns_order_dict_on_success():
+    client = MagicMock()
+    client.get_json.return_value = {"id": 1, "total": 42.50}
+    assert get_order(1, client) == {"id": 1, "total": 42.50}
+
+
+def test_returns_none_on_404():
+    client = MagicMock()
+    client.get_json.side_effect = HTTPError(status=404)
+    assert get_order(1, client) is None
+
+
+def test_raises_on_timeout():
+    client = MagicMock()
+    client.get_json.side_effect = HTTPTimeout()
+    with pytest.raises(HTTPTimeout):
+        get_order(1, client)
