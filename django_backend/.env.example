# Django Settings
DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production
# Optional. Fernet key for encrypted LLM credentials (python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())").
# If unset, encryption uses a key derived from SECRET_KEY (stable across restarts). Set this in production if you rotate SECRET_KEY without re-encrypting.
# ENCRYPTION_KEY=
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Dev: SQLite (default)
# Prod: postgresql://user:pass@localhost:5432/reviewhub
DATABASE_URL=sqlite:///db.sqlite3

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# FastAPI AI Engine
FASTAPI_URL=http://localhost:8001

# Optional server fallback: GitHub PAT for batch branch listing when users have not saved a token in Settings.
# Prefer per-user token: Settings → Profile → GitHub (encrypted in DB).
# GITHUB_TOKEN=

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-here
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
