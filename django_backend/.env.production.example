# LEERA production env — copy to django_backend/.env on the deploy host
# and fill in the placeholders. Used by docker-compose.prod.yml.
#
# Everything below the ### REQUIRED ### dividers must be filled in
# before the stack will start. Optional sections are marked.
#
# Generate the secrets with:
#     python -c "import secrets; print(secrets.token_urlsafe(64))"
# Generate per-secret — never reuse the same value across SECRET_KEY,
# JWT_SECRET_KEY, GITHUB_WEBHOOK_SECRET, etc.


# ╔══════════════════════════════════════════════════════════════════╗
# ║                            REQUIRED                              ║
# ╚══════════════════════════════════════════════════════════════════╝


# ─────────────────────────────────────────────────────────────────────
# Domain + TLS
# ─────────────────────────────────────────────────────────────────────
# The dogfood domain. Used by:
#   - nginx (envsubst into server_name + ssl_certificate paths)
#   - Let's Encrypt (cert subject + SAN — covers apex + www. only)
#   - Django ALLOWED_HOSTS, CORS, WEBHOOK_BASE_URL below
DOMAIN_NAME=on-boardia.com

# Email Let's Encrypt sends renewal-failure notices to. Use a real
# inbox you check — if auto-renew breaks, this is your only signal.
LETSENCRYPT_EMAIL=ops@on-boardia.com

# Set to 1 for Let's Encrypt's STAGING environment (rate-limit-
# friendly during initial bootstrap). Staging certs are NOT browser-
# trusted — only useful for verifying the pipeline. Switch to 0
# (default) for the real cert. Production rate limit: 5 cert
# issuances per domain per week.
LETSENCRYPT_STAGING=0


# ─────────────────────────────────────────────────────────────────────
# Django core
# ─────────────────────────────────────────────────────────────────────
DEBUG=false
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=<paste-the-64-char-secret-here>
ALLOWED_HOSTS=on-boardia.com,www.on-boardia.com
CORS_ALLOWED_ORIGINS=https://on-boardia.com,https://www.on-boardia.com
FRONTEND_URL=https://on-boardia.com


# ─────────────────────────────────────────────────────────────────────
# JWT — generate a SEPARATE key from SECRET_KEY
# ─────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=<paste-a-DIFFERENT-64-char-secret-here>
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7


# ─────────────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────
# These five variables together produce the connection string that
# docker-compose.prod.yml composes into DATABASE_URL:
#   postgres://${POSTGRES_USER}:${DB_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
#
# POSTGRES_HOST defaults to "db" — the in-compose Postgres service name.
# Change it to your DB hostname (or IP) when running against an
# external managed Postgres (RDS / Supabase / Neon / DO Managed DB).
# In that case you can also comment out the local `db` service in
# docker-compose.prod.yml so you're not running a Postgres container
# you don't use.
#
# If you'd rather skip these vars entirely, set DATABASE_URL directly
# (see the OPTIONAL section at the bottom of this file).
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=reviewhub
POSTGRES_USER=reviewhub
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
DB_PASSWORD=<paste-a-32-char-db-password-here>


# ─────────────────────────────────────────────────────────────────────
# Email — SMTP backend (default for now; switchable to Resend later)
# ─────────────────────────────────────────────────────────────────────
# users/emails.py logic:
#   - If RESEND_API_KEY is set, use the Resend SDK
#   - Otherwise fall back to Django's SMTP backend with the values below
#
# For dogfood we ship with SMTP. To switch to Resend later, just set
# RESEND_API_KEY in .env and `docker compose up -d` to roll the
# django container — no code or schema change.

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# ─── HOSTING-PROVIDER WARNING ───────────────────────────────────────
# DigitalOcean (and most VPS hosts) BLOCK outbound SMTP on ports
# 25, 465, and 587 by default to prevent abuse. This means:
#
#   - Gmail SMTP from a DO droplet: WILL NOT WORK without DO support
#     unblocking your account. Gmail only listens on 587/465.
#   - Brevo/SendGrid via port 587: same blockage.
#   - Brevo/SendGrid via port 2525: WORKS (DO doesn't block 2525).
#
# If you can't get SMTP working from the droplet, the diagnostic is:
#
#   docker compose -f docker-compose.prod.yml exec django python -c "
#   import socket; s = socket.socket()
#   s.settimeout(5); s.connect(('smtp.gmail.com', 587))"
#
#   - "Connection refused" / timeout → DO is blocking the port
#   - "Network is unreachable" → no IPv4 route (different issue)
#   - succeeds → SMTP layer works, debug at the auth/from-address level
#
# Two fixes if blocked:
#   A) Open a DO support ticket asking to unblock outbound SMTP
#   B) Switch to a provider that offers port 2525 (see Brevo below)
# ────────────────────────────────────────────────────────────────────
#
# Common SMTP providers — pick one and fill in. Examples:
#
#   Gmail (with an App Password — Google account → Security → 2-step verification → App passwords):
#     EMAIL_HOST=smtp.gmail.com
#     EMAIL_PORT=587               ← BLOCKED on DO droplets by default
#     EMAIL_HOST_USER=you@gmail.com
#     EMAIL_HOST_PASSWORD=<16-char-app-password-no-spaces>
#     EMAIL_USE_TLS=true
#
#   Brevo (formerly Sendinblue) on port 2525 — recommended for DO:
#     EMAIL_HOST=smtp-relay.brevo.com
#     EMAIL_PORT=2525              ← NOT blocked on DO
#     EMAIL_HOST_USER=<your-brevo-login>
#     EMAIL_HOST_PASSWORD=<your-smtp-key>
#     EMAIL_USE_TLS=true
#     # Free tier: 300 emails/day. Sender domain verification required.
#
#   SendGrid on port 2525:
#     EMAIL_HOST=smtp.sendgrid.net
#     EMAIL_PORT=2525              ← NOT blocked on DO (also offers 587)
#     EMAIL_HOST_USER=apikey
#     EMAIL_HOST_PASSWORD=<your-sendgrid-api-key>
#     EMAIL_USE_TLS=true
#
#   Mailgun:
#     EMAIL_HOST=smtp.eu.mailgun.org   (or smtp.mailgun.org for US)
#     EMAIL_PORT=587               ← BLOCKED on DO; Mailgun no 2525
#     EMAIL_HOST_USER=postmaster@<your-domain>
#     EMAIL_HOST_PASSWORD=<your-smtp-password>
#     EMAIL_USE_TLS=true

EMAIL_HOST=<smtp.your-provider.com>
EMAIL_PORT=587
EMAIL_HOST_USER=<your-smtp-username>
EMAIL_HOST_PASSWORD=<your-smtp-password-or-api-key>
EMAIL_USE_TLS=true
EMAIL_FROM=noreply@on-boardia.com

# Optional — switch to Resend later by setting this. Empty = use SMTP.
RESEND_API_KEY=


# ─────────────────────────────────────────────────────────────────────
# Webhooks (GitHub + GitLab signature secrets — used by ai-engine)
# ─────────────────────────────────────────────────────────────────────
# Public URL where GitHub can reach the ai-engine for push events.
# nginx terminates TLS and proxies /api/ai/ → ai-engine container.
WEBHOOK_BASE_URL=https://on-boardia.com/api/ai

# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# This same value goes into the GitHub webhook config (Settings →
# Webhooks → Secret) for every repo we monitor. Mismatch = "signature
# mismatch" rejection in ai-engine logs.
GITHUB_WEBHOOK_SECRET=<paste-a-32-char-shared-secret-here>

# Same idea for GitLab. Different secret if you don't want one
# compromise to affect the other; same is fine for v1 dogfood.
GITLAB_WEBHOOK_SECRET=<paste-another-32-char-shared-secret>


# ─────────────────────────────────────────────────────────────────────
# LLM provider (ai-engine)
# ─────────────────────────────────────────────────────────────────────
# LEERA business model: ONE shared API key, configured by the platform
# superadmin via Settings → LLM Configuration (encrypted at rest in
# the LLMConfiguration table). Schools using LEERA don't bring their
# own keys; cost flows to LEERA which bills the school per cohort.
#
# So LLM_API_KEY is NOT the source of truth here. Django reads the
# key from the DB (users/org_llm.py:_platform_llm_config()). ai-engine
# receives the key via the request payload from Django.
#
# What's left in env: just the model names for two-tier routing.
# ai-engine reads these to pick the right model per task:
#
#   PR_LLM_MODEL     — full-PR rubric grading sessions (best quality)
#                      Sonnet-class.
#   COMMIT_LLM_MODEL — commit-level inline reviews (cheap, fast)
#                      Haiku-class.
#
# Both must match LLM_PROVIDER (mixing Anthropic with an OpenAI model
# name produces a 404 from the upstream API).
LLM_PROVIDER=anthropic
PR_LLM_MODEL=claude-sonnet-4-5-20250929
COMMIT_LLM_MODEL=claude-haiku-4-5-20250929

# Legacy single-model fallback (consumed by ai-engine when the tier
# vars above are unset). Leave empty in production.
LLM_MODEL=
# Legacy fallback for the API key (consumed by ai-engine if the
# request payload from Django doesn't carry one). The DB-sourced key
# is the production path; this is a development-only safety net.
LLM_API_KEY=


# ╔══════════════════════════════════════════════════════════════════╗
# ║                          OPTIONAL                                ║
# ╚══════════════════════════════════════════════════════════════════╝


# Override DATABASE_URL directly if you want an external managed
# Postgres. When set, docker-compose still spins up the local db
# service but django ignores it. Comment out the local db service in
# docker-compose.prod.yml if you don't want it running.
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require
