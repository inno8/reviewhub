# Django Settings
DEBUG=false
SECRET_KEY=<generate-a-random-64-char-secret-key>
ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com

# Database (PostgreSQL for production)
DATABASE_URL=postgres://user:password@localhost:5432/reviewhub

# CORS — list only your frontend domain
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# FastAPI AI Engine — your production URL (NOT ngrok)
FASTAPI_URL=https://api.yourdomain.com

# JWT Settings
JWT_SECRET_KEY=<generate-a-different-random-64-char-key>
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Email — Resend for production
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
RESEND_API_KEY=<your-resend-api-key>
EMAIL_FROM=noreply@yourdomain.com

# Webhook base URL — public URL where GitHub can reach the AI engine
WEBHOOK_BASE_URL=https://api.yourdomain.com
