# LEERA production env — copy to django_backend/.env on the deploy host
# and fill in the placeholders. Used by docker-compose.prod.yml.

# ─────────────────────────────────────────────────────────────────────
# Domain + TLS
# ─────────────────────────────────────────────────────────────────────
# The dogfood domain. Used by:
#   - nginx (envsubst into the server_name + ssl_certificate paths)
#   - Let's Encrypt (cert subject + SAN)
#   - Django ALLOWED_HOSTS / CORS / WEBHOOK_BASE_URL below (replicate manually)
DOMAIN_NAME=on-boardia.com

# Email Let's Encrypt sends renewal-failure notices to. Use a real
# inbox you check — if the auto-renew breaks, this is your only signal.
LETSENCRYPT_EMAIL=ops@on-boardia.com

# Set to 1 to use Let's Encrypt's STAGING environment (rate-limit-
# friendly during initial bootstrap testing). Certs from staging are
# NOT browser-trusted — only useful for verifying the pipeline. Switch
# to 0 (default) for the real cert. Production rate limit: 5 cert
# issuances per domain per week, so don't bounce between staging/
# production unnecessarily.
LETSENCRYPT_STAGING=0

# ─────────────────────────────────────────────────────────────────────
# Django
# ─────────────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=<generate-a-random-64-char-secret-key>
ALLOWED_HOSTS=on-boardia.com,www.on-boardia.com
CORS_ALLOWED_ORIGINS=https://on-boardia.com,https://www.on-boardia.com
FRONTEND_URL=https://on-boardia.com

# ─────────────────────────────────────────────────────────────────────
# Database (PostgreSQL — Docker-compose runs the db service)
# ─────────────────────────────────────────────────────────────────────
DB_PASSWORD=<generate-a-strong-db-password>
# DATABASE_URL is composed inside docker-compose.prod.yml from DB_PASSWORD.

# ─────────────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=<generate-a-different-random-64-char-key>
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─────────────────────────────────────────────────────────────────────
# Email — Resend SDK in production. Falls back to Django SMTP if
# RESEND_API_KEY is empty.
# ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=<your-resend-api-key>
EMAIL_FROM=noreply@on-boardia.com
# SMTP fallback (only used if RESEND_API_KEY is unset):
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ─────────────────────────────────────────────────────────────────────
# Webhooks (GitHub + GitLab signature secrets — used by ai-engine)
# ─────────────────────────────────────────────────────────────────────
# Public URL where GitHub can reach the ai-engine for push events.
# In production this is https://<domain>/api/ai/, terminated by nginx.
WEBHOOK_BASE_URL=https://on-boardia.com/api/ai
GITHUB_WEBHOOK_SECRET=<generate-a-strong-shared-secret>
GITLAB_WEBHOOK_SECRET=<generate-a-strong-shared-secret>

# ─────────────────────────────────────────────────────────────────────
# LLM provider (ai-engine)
# ─────────────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_API_KEY=<your-anthropic-api-key>
LLM_MODEL=claude-3-5-haiku-20241022
